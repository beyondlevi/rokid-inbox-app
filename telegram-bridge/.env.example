# Telegram API credentials from https://my.telegram.org -> API development tools
API_ID=
API_HASH=

# Filled by `npm run login` (a StringSession for your already-authorized account).
TELEGRAM_SESSION=

# Shared secret the phone app sends as the "apikey" header (like Evolution).
BRIDGE_API_KEY=change-me

# Port the HTTP bridge listens on.
PORT=8787
